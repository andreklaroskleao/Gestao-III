rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid))
        : null;
    }

    function userExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userExists() ? userDoc().data : null;
    }

    function isActiveUser() {
      return userExists()
        && userData().deleted != true
        && userData().active == true;
    }

    function isMaster() {
      return isActiveUser()
        && userData().accessLevel == 'master';
    }

    function isAdmin() {
      return isActiveUser()
        && (
          userData().accessLevel == 'master' ||
          userData().role == 'Administrador'
        );
    }

    function hasPermission(area) {
      return isActiveUser()
        && (
          isMaster()
          || (userData().permissions is list && area in userData().permissions)
        );
    }

    function sameUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function canReadOwnUser(userId) {
      return isActiveUser() && sameUser(userId);
    }

    function canManageUsers() {
      return isAdmin() || hasPermission('users');
    }

    function validUserCreateData() {
      return request.resource.data.fullName is string
        && request.resource.data.username is string
        && request.resource.data.email is string
        && request.resource.data.role is string
        && request.resource.data.accessLevel is string
        && request.resource.data.permissions is list
        && request.resource.data.active is bool
        && request.resource.data.deleted is bool;
    }

    function validUserUpdateData() {
      return request.resource.data.fullName is string
        && request.resource.data.username is string
        && request.resource.data.email is string
        && request.resource.data.role is string
        && request.resource.data.accessLevel is string
        && request.resource.data.permissions is list
        && request.resource.data.active is bool
        && request.resource.data.deleted is bool;
    }

    match /users/{userId} {
      allow read: if canReadOwnUser(userId) || canManageUsers();

      allow create: if canManageUsers()
        && validUserCreateData();

      allow update: if (
          canManageUsers() && validUserUpdateData()
        ) || (
          canReadOwnUser(userId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['fullName', 'username', 'email', 'updatedAt'])
          && request.resource.data.active == resource.data.active
          && request.resource.data.deleted == resource.data.deleted
          && request.resource.data.role == resource.data.role
          && request.resource.data.accessLevel == resource.data.accessLevel
          && request.resource.data.permissions == resource.data.permissions
        );

      allow delete: if false;
    }

    match /settings/{docId} {
      allow read: if isActiveUser();
      allow create, update: if hasPermission('settings') || isAdmin();
      allow delete: if isMaster();
    }

    match /products/{docId} {
      allow read: if hasPermission('products') || hasPermission('sales');
      allow create, update: if hasPermission('products');
      allow delete: if isAdmin();
    }

    match /sales/{docId} {
      allow read: if hasPermission('sales') || hasPermission('reports');
      allow create: if hasPermission('sales');
      allow update: if hasPermission('sales') || isAdmin();
      allow delete: if isAdmin();
    }

    match /deliveries/{docId} {
      allow read: if hasPermission('deliveries');
      allow create, update: if hasPermission('deliveries');
      allow delete: if isAdmin();
    }

    match /clients/{docId} {
      allow read: if hasPermission('clients') || hasPermission('sales') || hasPermission('deliveries');
      allow create, update: if hasPermission('clients');
      allow delete: if isAdmin();
    }

    match /suppliers/{docId} {
      allow read: if hasPermission('suppliers') || hasPermission('products') || hasPermission('purchases') || hasPermission('payables');
      allow create, update: if hasPermission('suppliers');
      allow delete: if isAdmin();
    }

    match /inventory_movements/{docId} {
      allow read: if hasPermission('products') || hasPermission('reports');
      allow create: if hasPermission('products') || hasPermission('purchases');
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /audit_logs/{docId} {
      allow read: if hasPermission('settings') || isAdmin();
      allow create: if isActiveUser();
      allow update, delete: if false;
    }

    match /cash_sessions/{docId} {
      allow read: if hasPermission('settings') || hasPermission('reports') || isAdmin();
      allow create, update: if hasPermission('settings') || isAdmin();
      allow delete: if isMaster();
    }

    match /accounts_receivable/{docId} {
      allow read: if hasPermission('clients') || hasPermission('reports') || isAdmin();
      allow create, update: if hasPermission('clients') || isAdmin();
      allow delete: if isAdmin();
    }

    match /accounts_payable/{docId} {
      allow read: if hasPermission('payables') || hasPermission('purchases') || hasPermission('reports') || isAdmin();
      allow create, update: if hasPermission('payables') || hasPermission('purchases') || isAdmin();
      allow delete: if isAdmin();
    }

    match /purchase_orders/{docId} {
      allow read: if hasPermission('purchases') || isAdmin();
      allow create, update: if hasPermission('purchases') || isAdmin();
      allow delete: if isAdmin();
    }

    match /purchases/{docId} {
      allow read: if hasPermission('purchases') || hasPermission('reports') || isAdmin();
      allow create, update: if hasPermission('purchases') || isAdmin();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}